<Window x:Class="Astronometria.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Astronometria"
        mc:Ignorable="d"
        Title="Astronometria" Height="1500" Width="1500">

    <Window.Resources>
        <ControlTemplate x:Key="RoundedButtonTemplate" TargetType="Button">
            <Border Background="LightBlue" CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="RoundedPinkButtonTemplate" TargetType="Button">
            <Border Background="LightPink" CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.FontSize="20" TextBlock.FontWeight="Bold"/>
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="RoundedTextBoxTemplate" TargetType="TextBox">
            <Border Background="LightGray" CornerRadius="4">
                <ScrollViewer x:Name="PART_ContentHost" />
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="RoundedToggleButtonTemplate" TargetType="ToggleButton">
            <Border Background="MediumPurple"  CornerRadius="4">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="RadioButtonTemplate" TargetType="RadioButton">
            <ContentPresenter Height="60" Width="60" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </ControlTemplate>


    </Window.Resources>

    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>


        <DockPanel Grid.Row="0" Grid.Column="0">
                <DockPanel DockPanel.Dock="Top">

                    <!-- #region Date -->
                <Border BorderThickness="0.5" CornerRadius="8" BorderBrush="Gray" Margin="10, 10">
                    <StackPanel>
                        <DockPanel DockPanel.Dock="Top" HorizontalAlignment="Center">
                            <Label FontSize="24" Content="________Date________"/>
                        </DockPanel>

                        <DockPanel DockPanel.Dock="Bottom" Margin="10, 10">

                            <StackPanel Orientation="Vertical">

                                <Button Margin="0,5,0,0"  x:Name="BtPlusDay" Width="30" Height="15" Click="PlusDay" Template="{StaticResource RoundedButtonTemplate}" Content="V" RenderTransformOrigin="0.5,0.5" >
                                    <Button.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="180"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Button.RenderTransform>
                                </Button>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox HorizontalContentAlignment="Center" Margin="20, 0, 0, 0" x:Name="tbDay" Width="50" Height="30"  Template="{StaticResource RoundedTextBoxTemplate}"/>
                                    <Label  Width="20"  Height="50" Margin="0" Content="." FontSize="24"/>
                                </StackPanel>
                                <Button  x:Name="BtMinusDay" Width="30" Height="15" Margin="10, 10" Click="MinusDay" Template="{StaticResource RoundedButtonTemplate}" Content="V" />

                            </StackPanel>

                            <StackPanel Orientation="Vertical">
                                <Button Margin="0,5,0,0"  x:Name="BtPlusMonth" Width="30" Height="15" Click="PlusMonth" Template="{StaticResource RoundedButtonTemplate}" Content="V" RenderTransformOrigin="0.5,0.5" >
                                    <Button.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="180"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Button.RenderTransform>
                                </Button>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox HorizontalContentAlignment="Center" x:Name="tbMonth" Width="50" Height="30" Margin="5,5" Template="{StaticResource RoundedTextBoxTemplate}"/>
                                    <Label  Width="20" Height="50" Margin="0" Content="." FontSize="24" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <Button  x:Name="BtMinusMonth" Width="30" Height="15" Margin="10, 10" Click="MinusMonth" Template="{StaticResource RoundedButtonTemplate}" Content="V" />

                            </StackPanel>

                            <StackPanel Orientation="Vertical">

                                <Button Margin="0,5,0,0"  x:Name="BtPlusYear" Width="30" Height="15" Click="PlusYear" Template="{StaticResource RoundedButtonTemplate}" Content="V" RenderTransformOrigin="0.5,0.5" >
                                    <Button.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="180"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Button.RenderTransform>
                                </Button>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                    <TextBox HorizontalContentAlignment="Center" x:Name="tbYear" Width="50" Height="30" Margin="5,10"  Template="{StaticResource RoundedTextBoxTemplate}"/>

                                </StackPanel>
                                <Button  x:Name="BtMinusYear" Width="30" Height="15" Margin="10, 10" Click="MinusYear" Template="{StaticResource RoundedButtonTemplate}" Content="V" />

                            </StackPanel>

                        </DockPanel>
                    </StackPanel>
                </Border>
            </DockPanel>
                <!-- Top -->
            <!-- #endregion -->


            <DockPanel DockPanel.Dock="Bottom">
                <DockPanel DockPanel.Dock="Top">
                    <Border BorderThickness="0.5" CornerRadius="8" BorderBrush="Gray" Margin="10, 10">
                        <StackPanel VerticalAlignment="Top" Margin="0, 20">
                            <Label Content="Max. Mag" HorizontalContentAlignment="Center" FontSize="24"/>
                            <StackPanel Margin="20,20,0,0" >
                                <!--    <RadioButton x:Name="RB_1mag" Content="1" FontSize="16" Checked = "mag1Checked" Unchecked = "mag1Unchecked" Click="RBUpdateStarsInMap" Margin="10, 30, 0, 0"/> -->
                                <RadioButton x:Name="RB_2mag" Content="2" FontSize="16" Checked = "mag2Checked" Unchecked = "mag2Unchecked" Click="RBUpdateStarsInMap" Margin="10, 10, 0, 0"/>
                                <RadioButton x:Name="RB_3mag" Content="3" FontSize="16" Checked = "mag3Checked" Unchecked = "mag3Unchecked" Click="RBUpdateStarsInMap" Margin="10, 10, 0, 0"/>
                                <RadioButton x:Name="RB_4mag" Content="4" FontSize="16"  Checked = "mag4Checked" Unchecked = "mag4Unchecked" Click="RBUpdateStarsInMap" Margin="10, 10, 0, 0"/>
                                <RadioButton x:Name="RB_55mag" Content="5" FontSize="16" Checked = "mag55Checked" Unchecked = "mag55Unchecked" Click="RBUpdateStarsInMap" Margin="10, 10, 0, 0"/> 
                                <!--    <RadioButton x:Name="RB_6mag" Content="6" FontSize="16" Checked = "mag6Checked" Unchecked = "mag6Unchecked" Click="RBUpdateStarsInMap" Margin="10, 10, 0, 0"/> -->
                                <RadioButton x:Name="RB_65mag" Content="6.5" FontSize="16" Checked = "mag65Checked" Unchecked = "mag65Unchecked" Click="RBUpdateStarsInMap" Margin="10, 10, 0, 0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DockPanel>
                
                <DockPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" HorizontalAlignment="Left">
                    <Border BorderThickness="0.5" CornerRadius="8" BorderBrush="Gray" Margin="10, 10">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20, 20, 0, 0">
                        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                            <TextBox Margin="20, 0, 0, 0" x:Name="tbGeoLong" Width="50" Height="30"  Template="{StaticResource RoundedTextBoxTemplate}"/>
                            <Label  VerticalContentAlignment="Center" Width="150"  Height="50"  Content="Geogr. Length" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                            <TextBox Margin="20, 0, 0, 0" x:Name="tbGeoLat" Width="50" Height="30"  Template="{StaticResource RoundedTextBoxTemplate}"/>
                            <Label VerticalContentAlignment="Center" Width="150"  Height="50"  Content="Geogr. Latitute" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                            <TextBox Margin="20, 0, 0, 0" x:Name="tbTimeZone" Width="50" Height="30"  Template="{StaticResource RoundedTextBoxTemplate}"/>
                            <Label VerticalContentAlignment="Center" Width="150"  Height="50"  Content="Time zone (+/- hours)" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                            <CheckBox  x:Name="cbDaylightSavingsTime" Content="Daylight Savings Time"  Checked = "DaylightSavingsChecked" Unchecked = "DaylightSavingsUnchecked" 
                                       Click="CBDayUpdateDaylightSavingsTime" Margin="20, 20, 0, 20"/>
                        </StackPanel>
                    </StackPanel>
                        </Border> 
                </DockPanel>

            </DockPanel>
        </DockPanel>

        <DockPanel Grid.Row="0" Grid.Column="1" LastChildFill="True"> <!-- LastChildFill True bewirkt, dass das Canvas den kompletten Restplatz einnimmt -> WICHTIG! -->
            <DockPanel DockPanel.Dock="Top">
                <Label FontSize="30" Content="North" HorizontalAlignment="Center"/>
            </DockPanel>

            <DockPanel DockPanel.Dock="Bottom" Margin="10, 10">

                <DockPanel DockPanel.Dock="Bottom">
                    <Label FontSize="30" Content="South" HorizontalAlignment="center" VerticalAlignment="Bottom"/>
                </DockPanel>
                
                <DockPanel DockPanel.Dock="Top">

                    <local:StarMapControl
                        x:Name="StarMapControl"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" />


                </DockPanel> 



            </DockPanel>

        </DockPanel>


        <DockPanel Grid.Row="0" Grid.Column="2">

            <!-- links oben -->
            <DockPanel DockPanel.Dock="Top">
                <DockPanel DockPanel.Dock="Top">
                    <Border BorderThickness="0.5" CornerRadius="8" BorderBrush="Gray" Margin="10, 10">
                        <StackPanel>
                            <DockPanel DockPanel.Dock="Top" HorizontalAlignment="Center">
                                <Label FontSize="24" Content="________Time________"/>
                            </DockPanel>


                            <DockPanel DockPanel.Dock="Bottom" Margin="10, 10">
                                <DockPanel DockPanel.Dock="Left">
                                    <!-- Hour -->
                                    <StackPanel Orientation="Vertical">

                                        <Button Margin="0,5,0,0"  x:Name="BtPlusHour" Width="30" Height="15" Click="PlusHour" Template="{StaticResource RoundedButtonTemplate}" Content="V" RenderTransformOrigin="0.5,0.5" >
                                            <Button.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform/>
                                                    <SkewTransform/>
                                                    <RotateTransform Angle="180"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </Button.RenderTransform>
                                        </Button>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox HorizontalContentAlignment="Center" Margin="20, 0, 0, 0" x:Name="tbHour" Width="50" Height="30"  Template="{StaticResource RoundedTextBoxTemplate}"/>
                                            <Label  Width="50"  Height="50" Margin="0" Content="h" FontSize="24"/>
                                        </StackPanel>

                                        <Button  x:Name="BtMinusHour" Width="30" Height="15" Margin="10, 10" Click="MinusHour" Template="{StaticResource RoundedButtonTemplate}" Content="V" />

                                    </StackPanel>

                                    <!-- Minute -->
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">

                                        <Button Margin="-5,5,0,0"  x:Name="BtPlusMinute" Width="30" Height="15" Click="PlusMinute" 
                                    Template="{StaticResource RoundedButtonTemplate}" Content="V" RenderTransformOrigin="0.5,0.5" >
                                            <Button.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform/>
                                                    <SkewTransform/>
                                                    <RotateTransform Angle="180"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </Button.RenderTransform>
                                        </Button>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBox HorizontalContentAlignment="Center" x:Name="tbMinute" Width="50" Height="30" Margin="15,5,5,5" Template="{StaticResource RoundedTextBoxTemplate}"/>
                                            <Label  Width="50" Height="50" Margin="0" Content="m" FontSize="24" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <Button  x:Name="BtMinusMinute" Width="30" Height="15" Margin="5,10,10,10" Click="MinusMinute" Template="{StaticResource RoundedButtonTemplate}" Content="V" />

                                    </StackPanel>


                                    <!-- Second -->
                                    <!--  second -->

                                </DockPanel>
                                <!-- end of bottom -->
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </DockPanel> <!-- endof rechtsoben -->
                
           <!-- </Border> -->

            <DockPanel DockPanel.Dock="Bottom" >
                    <DockPanel DockPanel.Dock="Top" >
                        <Border BorderThickness="0.5" CornerRadius="8" BorderBrush="Gray" Margin="10, 10">
                            <StackPanel VerticalAlignment="Top" Margin="0, 20">
                                <Label Content="Objects" HorizontalContentAlignment="Center" FontSize="24"/>
                                <StackPanel HorizontalAlignment="Right" Margin="0,0,50,0">
                                    <CheckBox FlowDirection="RightToLeft" x:Name="CB_Stars" Content="Stars"  Checked = "CBStarsChecked" Unchecked = "CBStarsUnchecked" Click="CBUpdateStarsInMap" Margin="10, 30, 0, 0"/>
                                    <CheckBox FlowDirection="RightToLeft" x:Name="CB_Constellations" Content="Constellations" Checked = "CBStarsChecked" Unchecked = "CBStarsUnchecked" Click="CBUpdateConstellationsInMap" Margin="10, 30, 0, 0"/>
                                    <CheckBox FlowDirection="RightToLeft" x:Name="CB_Planets" Content="Planets"  Checked = "CBPlanetsChecked" Unchecked = "CBPlanetsUnchecked" Click="CBUpdatePlanetsInMap" Margin="10, 30, 0, 0"/>
                                    <!--               <CheckBox FlowDirection="RightToLeft" x:Name="CB_Messier" Content="Planets" Checked = "CBMessierChecked" Unchecked = "CBMessierUnchecked" Click="CBUpdateMessierInMap" Margin="10, 30, 0, 0"/> -->
                                    <CheckBox FlowDirection="RightToLeft" x:Name="CB_Circles" Content="Circles"  Checked = "CBCirclesChecked" Unchecked = "CBCirclesUnchecked" Click="CBUpdateCirclesInMap" Margin="10, 30, 0, 0"/>
                                    <!--               <CheckBox FlowDirection="RightToLeft" x:Name="CB_Sky" Content="Sky"  Checked = "CBSkyChecked" Unchecked = "CBSkyUnchecked" Click="CBUpdateSkyInMap" Margin="10, 30, 0, 0"/> -->
                                    <CheckBox FlowDirection="RightToLeft" x:Name="CB_StarColors" Content="Star Colors" Checked = "CBStarColorsChecked" Unchecked = "CBStarColorsUnchecked" Click="CBUpdateStarColorsInMap" Margin="10, 30, 0, 0"/>
                                    <!--               <CheckBox FlowDirection="RightToLeft" x:Name="CB_StarNames" Content="Star Colors" Checked = "CBStarNamesChecked" Unchecked = "CBStarNamesUnchecked" Click="CBUpdateStarNamesInMap" Margin="10, 30, 0, 0"/>^-->
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DockPanel>


                    <DockPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Margin="0, 10, 0, 0">
                        <Border BorderThickness="0.5" CornerRadius="8" BorderBrush="Gray" Margin="10, 10">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0, 20, 0, 20">
                                <Button  Width="100" Height="60" Margin="20, 10"  Click="Now" Template="{StaticResource RoundedPinkButtonTemplate}" Content="Now"/>
                                <Button x:Name="Start" Width="100" Height="60" Margin="20, 10" Click="Refresh" HorizontalAlignment="Left" Template="{StaticResource RoundedPinkButtonTemplate}" Background="#FF60D6D3" Content="Refresh"/>
                            </StackPanel>
                        </Border>
                    </DockPanel>
     

                </DockPanel>
        </DockPanel> <!-- Bottom -->
    </DockPanel> <!-- rechte Spalte -->
    
    </Grid>
</Window>
